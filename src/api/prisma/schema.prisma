// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique @db.VarChar(255)
  fullName     String         @db.VarChar(120)
  passwordHash String
  createdAt    DateTime       @default(now()) @db.Timestamptz
  updatedAt    DateTime       @default(now()) @db.Timestamptz
  projects     VideoProject[]

  @@map("users")
}

model AIVoice {
  id          String            @id @default(uuid()) @db.Uuid
  name        String            @db.VarChar(100)
  provider    String            @db.VarChar(50)
  gender      String            @db.VarChar(10)
  locale      String            @db.VarChar(10)
  previewUrl  String?
  isActive    Boolean           @default(true)
  generations VideoGeneration[]

  @@map("ai_voices")
}

model StylePreset {
  id                String            @id @default(uuid()) @db.Uuid
  name              String            @db.VarChar(100)
  visualDescription String?
  baseImagePrompt   String?
  negativePrompt    String?
  createdAt         DateTime          @default(now()) @db.Timestamptz
  generations       VideoGeneration[]

  @@map("style_presets")
}

model VideoProject {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @db.Uuid
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String            @db.VarChar(255)
  storyTopic     String?
  videoGenre     String?           @db.VarChar(100)
  status         String            @default("draft") @db.VarChar(20)
  createdAt      DateTime          @default(now()) @db.Timestamptz
  updatedAt      DateTime          @default(now()) @db.Timestamptz
  entities       ProjectEntity[]
  scripts        VideoScript[]
  generations    VideoGeneration[]

  @@map("video_projects")
}

model ProjectEntity {
  id           String       @id @default(uuid()) @db.Uuid
  projectId    String       @db.Uuid
  project      VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType   String       @db.VarChar(20)
  name         String       @db.VarChar(255)
  description  String?
  refImageUrl  String?
  metaJson     Json?
  createdAt    DateTime     @default(now()) @db.Timestamptz

  @@map("project_entities")
}

model VideoScript {
  id          String            @id @default(uuid()) @db.Uuid
  projectId   String            @db.Uuid
  project     VideoProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int               @default(1)
  content     Json
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now()) @db.Timestamptz
  generations VideoGeneration[]

  @@map("video_scripts")
}

model VideoGeneration {
  id              String       @id @default(uuid()) @db.Uuid
  projectId       String       @db.Uuid
  project         VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scriptId        String?      @db.Uuid
  script          VideoScript? @relation(fields: [scriptId], references: [id])
  voiceId         String?      @db.Uuid
  voice           AIVoice?     @relation(fields: [voiceId], references: [id])
  styleId         String?      @db.Uuid
  style           StylePreset? @relation(fields: [styleId], references: [id])
  generationNo    Int
  resolution      String       @db.VarChar(20)
  aspectRatio     String       @db.VarChar(10)
  motionIntensity Int          @default(50)
  status          String       @default("pending") @db.VarChar(20)
  outputUrl       String?
  thumbnailUrl    String?
  durationSeconds Int?
  createdAt       DateTime     @default(now()) @db.Timestamptz
  scenes          VideoScene[]

  @@map("video_generations")
}

model VideoScene {
    id           String          @id @default(uuid()) @db.Uuid
    generationId String          @db.Uuid
    generation   VideoGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
    sceneOrder   Int
    visualPrompt String?
    motionPrompt String?
    audioScript  String?
    imageUrl     String?
    videoClipUrl String?
    audioUrl     String?
    metadata     Json?
    createdAt    DateTime        @default(now()) @db.Timestamptz

    @@map("video_scenes")
}
