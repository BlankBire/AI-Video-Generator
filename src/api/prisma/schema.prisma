// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
  engineType    = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  fullName     String
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())
  projects     VideoProject[]

  @@map("users")
}

model AIVoice {
  id          String            @id @default(uuid())
  name        String
  provider    String
  gender      String
  locale      String
  previewUrl  String?
  isActive    Boolean           @default(true)
  generations VideoGeneration[]

  @@map("ai_voices")
}

model StylePreset {
  id                String            @id @default(uuid())
  name              String
  visualDescription String?
  baseImagePrompt   String?
  negativePrompt    String?
  createdAt         DateTime          @default(now())
  generations       VideoGeneration[]

  @@map("style_presets")
}

model VideoProject {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  storyTopic  String?
  videoGenre  String?
  status      String            @default("draft")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now())
  entities    ProjectEntity[]
  scripts     VideoScript[]
  generations VideoGeneration[]

  @@map("video_projects")
}

model ProjectEntity {
  id          String       @id @default(uuid())
  projectId   String
  project     VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType  String
  name        String
  description String?
  refImageUrl String?
  metaJson    String?
  createdAt   DateTime     @default(now())

  @@map("project_entities")
}

model VideoScript {
  id          String            @id @default(uuid())
  projectId   String
  project     VideoProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int               @default(1)
  content     String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  generations VideoGeneration[]

  @@map("video_scripts")
}

model VideoGeneration {
  id              String       @id @default(uuid())
  projectId       String
  project         VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scriptId        String?
  script          VideoScript? @relation(fields: [scriptId], references: [id])
  voiceId         String?
  voice           AIVoice?     @relation(fields: [voiceId], references: [id])
  styleId         String?
  style           StylePreset? @relation(fields: [styleId], references: [id])
  generationNo    Int
  resolution      String
  aspectRatio     String
  motionIntensity Int          @default(50)
  status          String       @default("pending")
  outputUrl       String?
  thumbnailUrl    String?
  durationSeconds Int?
  createdAt       DateTime     @default(now())
  scenes          VideoScene[]

  @@map("video_generations")
}

model VideoScene {
  id           String          @id @default(uuid())
  generationId String
  generation   VideoGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  sceneOrder   Int
  visualPrompt String?
  motionPrompt String?
  audioScript  String?
  imageUrl     String?
  videoClipUrl String?
  audioUrl     String?
  metadata     String?
  createdAt    DateTime        @default(now())

  @@map("video_scenes")
}
